# Copy to `.env` and fill in values. Never commit `.env`.
#
# FatSecret Platform API — https://platform.fatsecret.com/api/
# - FATSECRET_CLIENT_ID may be exposed to the app (via app.config `extra`) for public OAuth flows.
# - FATSECRET_CLIENT_SECRET must stay out of the mobile bundle. Use a backend, EAS Server
#   Function, or dev-only tooling to exchange tokens; do not prefix with EXPO_PUBLIC_.
#
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# Maps (existing) — https://docs.expo.dev/versions/latest/sdk/map-view/
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
